{
  "version": 1,
  "rules": [
    {
      "id": "uncategorized_movement_review",
      "enabled": true,
      "kind": "uncategorized_movement",
      "tipo": "revision_manual",
      "classification": "revision_manual",
      "severity": "medium",
      "title_template": "Movimientos sin categoría para revisar",
      "description_template": "Hay {count} movimiento(s) sin categoría en {periodo}.",
      "thresholds": {
        "medium_amount": 30000,
        "high_amount": 100000,
        "high_count": 3
      },
      "suggested_action": "Revisar la bandeja de movimientos sin categoría y decidir si corresponde crear una regla cascada."
    },
    {
      "id": "income_dependency_shift",
      "enabled": true,
      "kind": "income_dependency",
      "tipo": "dependencia",
      "classification": "insight",
      "severity": "high",
      "title_template": "Concentración de ingresos en {source}",
      "description_template": "{source} concentra {share_pct}% de los ingresos del período.",
      "thresholds": {
        "critical_share": 0.7,
        "change_vs_baseline": 0.25,
        "min_baseline_periods": 4,
        "max_candidates": 3
      },
      "exclude_structural_entities": true,
      "excluded_sources": [
        "Entrada",
        "FCI",
        "Intereses",
        "Devoluciones",
        "Cheques Rechazados",
        "Descuentos"
      ],
      "structural_entities": [
        "OSPACA",
        "Obra social",
        "Cuenta Propia",
        "Cuotas Afiliados",
        "Financiacion",
        "Extracapita"
      ],
      "suggested_action": "Validar si la concentración responde a un cambio real, timing de cobro o dependencia operativa."
    },
    {
      "id": "category_variation_vs_baseline",
      "enabled": true,
      "kind": "category_variation",
      "tipo": "anomalia",
      "classification": "anomalia",
      "severity": "medium",
      "group_by": "category_subcategory",
      "title_template": "Variación relevante en {label}",
      "description_template": "{label} varió {change_pct}% contra su promedio histórico.",
      "thresholds": {
        "change_vs_baseline": 0.45,
        "min_baseline_periods": 4,
        "min_current_amount": 500000,
        "min_abs_delta": 300000,
        "max_candidates": 6
      },
      "excluded_labels": [
        "Transferencias > Entrada",
        "Transferencias > Salida",
        "Impuestos > Bancarios",
        "Impuestos y Comisiones > IVA",
        "Impuestos y Comisiones > Comisiones Bancarias",
        "Impuestos y Comisiones > Comisiones Cheques",
        "Impuestos y Comisiones > Percepciones",
        "Impuestos y Comisiones > Percepciones IVA",
        "Impuestos y Comisiones > Devolución Impuesto al Cheque",
        "Beneficios > Descuentos"
      ],
      "suggested_action": "Abrir la categoría y revisar si el desvío corresponde a una operación esperada o a un evento extraordinario."
    },
    {
      "id": "expected_recurrent_baseline",
      "enabled": true,
      "kind": "expected_recurrent",
      "tipo": "kpi",
      "classification": "kpi",
      "severity": "info",
      "default_review_status": "ignored",
      "title_template": "Movimiento recurrente esperado: {source}",
      "description_template": "{source} aparece como comportamiento estructural del período.",
      "thresholds": {
        "min_baseline_periods": 2,
        "min_current_count": 1
      },
      "structural_entities": [
        "OSPACA",
        "Cuenta Propia",
        "Cuotas Afiliados",
        "Financiacion",
        "Extracapita",
        "Sueldos",
        "Nómina",
        "AFIP",
        "Visa",
        "Alquiler",
        "Cheques",
        "Farmacias",
        "Sancor",
        "Agua",
        "Gas",
        "Internet/TV",
        "Nube",
        "Sistema ERP",
        "Telefonía"
      ],
      "suggested_action": "Mantener como baseline/KPI. No elevar como insight destacado salvo que cambie contra su patrón histórico."
    }
  ]
}
